# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=bycigar

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Auth
JWT_SECRET=your-jwt-secret-key

# Uploads
UPLOAD_DIR=/opt/bycigar/uploads

# Cleanup (days)
CLEANUP_SOFT_DELETE_DAYS=30
CLEANUP_CART_STALE_DAYS=90
CLEANUP_ORDER_ARCHIVE_DAYS=365
CLEANUP_CHAT_RETENTION_DAYS=30
CLEANUP_NOTIF_READ_DAYS=60
CLEANUP_NOTIF_UNREAD_DAYS=120
